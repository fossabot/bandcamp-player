{
  "name": "xyz.eremef.beta",
  "productName": "Beta Player",
  "main": "index.js",
  "expo": {
    "autolinking": {
      "ios": {
        "exclude": [
          "react-native-volume-manager"
        ]
      }
    }
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:apk": "npx eas-cli build --platform android",
    "build:locally": "npx eas-cli build --platform android --local --profile production",
    "test": "jest",
    "lint": "cd .. && eslint mobile",
    "typecheck": "tsc --noEmit",
    "android:build": "npm run sync-assets && expo run:android",
    "android:build:dev": "cross-env EXPO_DEV_PACKAGE=xyz.eremef.bandcamp.remote.dev npm run android:build",
    "sync-assets": "node ../scripts/generate-config-hash.js && node ../scripts/copy-assets.js",
    "prebuild": "npm run sync-assets",
    "expo:prebuild": "npx expo prebuild --clean -p android",
    "prestart": "npm run sync-assets"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@preeternal/react-native-cookie-manager": "^6.3.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.2.0",
    "@rntp/player": "^5.5.0",
    "cheerio": "1.0.0-rc.12",
    "expo": "~56.0.11",
    "expo-asset": "~56.0.17",
    "expo-background-fetch": "~56.0.19",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-linking": "~56.0.14",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "js-base64": "^3.7.8",
    "js-md5": "^0.8.3",
    "js-sha256": "^0.11.1",
    "lucide-react-native": "^0.577.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-volume-manager": "^2.0.8",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "shaka-player": "^4.16.30",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/js-md5": "^0.8.0",
    "@types/react": "~19.2.11",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "~56.0.0",
    "cross-env": "^10.1.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "metro-config": "^0.83.3",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "private": true
}
